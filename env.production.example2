# PRODUCTION .env — lives ONLY on the server, never committed to git.
# Copy this to .env in your project root on the droplet and fill in real values.

# --- Core Django ---
# Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY="2p2bbu@56kj=zw0k*_oltbo2r4y$#4#m_tpybi8m7s3_zb(13d"
DJANGO_DEBUG=False

# Your droplet's IP address, and/or your domain once you have one, comma separated:
DJANGO_ALLOWED_HOSTS=your_droplet_ip,yourdomain.com

# Full origin(s) including scheme — needed so the admin login and any forms
# (e.g. your quote/contact form) pass Django's CSRF check:
DJANGO_CSRF_TRUSTED_ORIGINS=http://your_droplet_ip

# Keep this False until Certbot/HTTPS is actually set up on a real domain.
# Flip to True only after https:// works in a browser.
DJANGO_USE_HTTPS=False

# --- Database ---
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
# DATABASE_URL=postgres://myprojectuser:changeme@localhost:5432/myproject
DATABASE_URL=postgres://admin:pikachuraichuzenzense@localhost:5432/spfm
# --- Business fallback details ---
BUSINESS_PHONE=1300 000 000
BUSINESS_PHONE_TEL=+611300000000
BUSINESS_EMAIL=info@spfacilitiesmgmt.com.au
BUSINESS_ADDRESS=Suite 4, 120 Example Street, Sydney NSW 2000

# --- Email notifications ---
# Set to smtp once you have real credentials; console just logs emails.
DJANGO_EMAIL_BACKEND=console
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=website@spfacilitiesmgmt.com.au
OWNER_NOTIFICATION_EMAIL=info@spfacilitiesmgmt.com.au

# --- SMS notifications (optional, via Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
OWNER_SMS_NUMBER=
