# Copy this file to .env and fill in real values.
# Nothing here is required for local development — sensible defaults are
# built in — but you'll want to set these before going to production.

# --- Core Django ---
DJANGO_SECRET_KEY=
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Business fallback details ---
# These are only used to seed the very first row of Site Settings on first
# migrate. After that, edit contact details from /admin/ instead (Site
# Settings) — changes there apply sitewide instantly (US-7.6).
BUSINESS_PHONE=1300 000 000
BUSINESS_PHONE_TEL=+611300000000
BUSINESS_EMAIL=info@spfacilitiesmgmt.com.au
BUSINESS_ADDRESS=Suite 4, 120 Example Street, Sydney NSW 2000

# --- Email notifications (Epic 6) ---
# In development, notification emails print to the console (no setup
# needed). Set DJANGO_EMAIL_BACKEND=smtp to send real emails.
DJANGO_EMAIL_BACKEND=console
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=website@spfacilitiesmgmt.com.au
# Inbox that receives new quote/contact leads:
OWNER_NOTIFICATION_EMAIL=info@spfacilitiesmgmt.com.au

# --- SMS notifications (optional, via Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
OWNER_SMS_NUMBER=
